# SQLite-database (fil-sti relativ til prisma/)
DATABASE_URL="file:./dev.db"

# Auth.js — generér en hemmelig nøgle med: npx auth secret
AUTH_SECRET="skift-mig-til-en-tilfaeldig-streng"

# Anthropic API-key til AI-stylisten på storefront (/api/assistant/chat).
# Uden denne returnerer endpointet 503 og chat-vinduet viser en pæn fejl.
# Få en key på https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Unsplash API-key til billed-søgning fra admin-chat (images.search_unsplash).
# Uden denne kan AI'en ikke foreslå billeder til nye produkter.
# Få en gratis dev-key på https://unsplash.com/oauth/applications (50 req/time)
UNSPLASH_ACCESS_KEY=""

# Phase 4: Stripe (real payment via webhook). Sætter via /admin/integrations
# i stedet for env hvis du foretrækker DB-baseret config.
# STRIPE_SECRET_KEY=""
# STRIPE_PUBLISHABLE_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# Phase 4: Resend email-service (afløser PreviewMailer i production).
# RESEND_API_KEY=""

# Phase 4: Sentry error-tracking (kritisk for production). No-op uden DSN.
# Server-side DSN (privat):
# SENTRY_DSN=""
# Client-side DSN (offentlig, bundlet i JS):
# NEXT_PUBLIC_SENTRY_DSN=""
# Build-time source-map upload (sættes i Vercel project env, ikke lokalt).
# Token genereres på https://sentry.io/settings/auth-tokens/ med scopes
# project:releases + org:read.
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN=""

# Phase 4: Vercel Cron auth-secret for /api/cron/reconcile-stripe.
# Genereres med: openssl rand -hex 32
# CRON_SECRET=""
