NEXT_PUBLIC_ORAMA_DATASOURCE_ID="Rest API data source ID"
NEXT_PUBLIC_ORAMA_PROJECT_ID="project ID"
NEXT_PUBLIC_ORAMA_API_KEY="public API key"

# keep it secretly!
ORAMA_PRIVATE_API_KEY="private API key"
# --- Cartwright Plus (all optional — unset means: waitlist CTA stays, webhook
# --- answers 501, success page explains gracefully; nothing breaks) ---

# Stripe Payment Link for the Plus tier ($49/mo recurring). Setting it flips the
# pricing-page CTA from waitlist to "Get Plus".
STRIPE_LINK_PLUS=""
# The Stripe Price id (price_...) the Plus Payment Link sells — fulfillment rejects any other price.
STRIPE_PLUS_PRICE_ID=""
# Stripe secret API key (sk_...) — server-side session retrieval, webhook, subscription lookups.
STRIPE_SECRET_KEY=""
# Signing secret (whsec_...) for the /api/webhooks/stripe endpoint.
STRIPE_WEBHOOK_SECRET=""
# No-code Stripe customer-portal login URL shown on the success page + activation email.
STRIPE_PORTAL_URL=""
# Ed25519 private key that signs Plus access keys — PEM (PKCS#8), base64 of the PEM, or base64 PKCS#8 DER (see lib/plus-token.ts header for the generator one-liner). NEVER commit a real key.
CARTWRIGHT_PLUS_SIGNING_PRIVATE_KEY=""
# Key id (kid) stamped into issued keys, e.g. "2026-01" — rotate together with the keypair.
CARTWRIGHT_PLUS_SIGNING_KEY_ID=""
# From-address for the Plus activation email (default: noreply@cartwright.app).
PLUS_FROM_EMAIL=""
