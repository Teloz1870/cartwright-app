{
  "name": "create-cartwright",
  "version": "2.1.3",
  "description": "Scaffolder for AI-first webshops powered by Cartwright",
  "keywords": [
    "cartwright",
    "nextjs",
    "scaffolder",
    "starter",
    "template",
    "ecommerce",
    "ai",
    "mcp",
    "stripe"
  ],
  "type": "module",
  "bin": {
    "create-cartwright": "dist/index.js",
    "cartwright": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "giget": "^1.2.5",
    "picocolors": "^1.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Teloz1870/cartwright-app.git",
    "directory": "apps/cli"
  },
  "homepage": "https://cartwright.app",
  "bugs": "https://github.com/Teloz1870/cartwright-app/issues"
}
